{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/wing-definition.schema.json",
  "title": "Multi-Wing Generator Definition",
  "description": "Declarative input schema for generating CI-verifiable Multi-Wing Orchestration structures.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generator_id",
    "created_at",
    "target",
    "wings",
    "global_rules",
    "generator_config"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "generator_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_name",
        "output_schema_title",
        "output_schema_id",
        "output_schema_filename"
      ],
      "properties": {
        "protocol_name": {
          "type": "string",
          "minLength": 1
        },
        "output_schema_title": {
          "type": "string",
          "minLength": 1
        },
        "output_schema_id": {
          "type": "string",
          "format": "uri"
        },
        "output_schema_filename": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "wings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "wing_id",
          "wing_name",
          "purpose",
          "allowed_outputs",
          "prohibited_outputs",
          "handoff_to",
          "blocking_conditions",
          "requires_human_review",
          "emits_trace_receipt"
        ],
        "properties": {
          "wing_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "wing_name": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "allowed_outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "prohibited_outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "handoff_to": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_-]*$"
            }
          },
          "blocking_conditions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "requires_human_review": {
            "type": "boolean"
          },
          "emits_trace_receipt": {
            "type": "boolean"
          }
        }
      }
    },
    "global_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "safety_boundary",
        "human_review",
        "trace_receipt",
        "orchestration_receipt"
      ],
      "properties": {
        "safety_boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "prohibited_uses",
            "escalation_conditions"
          ],
          "properties": {
            "prohibited_uses": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "escalation_conditions": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "human_review": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "reviewer_role",
            "review_triggers"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "reviewer_role": {
              "type": "string",
              "minLength": 1
            },
            "review_triggers": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "trace_receipt": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "required_fields"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "required_fields": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "orchestration_receipt": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required_fields"
          ],
          "properties": {
            "required_fields": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "generator_config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_directory",
        "strict_additional_properties",
        "include_generated_example"
      ],
      "properties": {
        "output_directory": {
          "type": "string",
          "minLength": 1
        },
        "strict_additional_properties": {
          "type": "boolean"
        },
        "include_generated_example": {
          "type": "boolean"
        }
      }
    }
  }
}
